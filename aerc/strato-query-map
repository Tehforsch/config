# Query map for the Strato-hosted sokobrane account.
# Folder names match the local Maildir names from mbsync.

inbox=folder:strato/inbox
drafts=folder:strato/drafts
sent=folder:strato/sent
deleted=folder:strato/deleted
archive=folder:strato/archive
spam=folder:strato/spam or tag:spam

all=folder:strato
unread=tag:unread and folder:strato
flagged=tag:flagged and folder:strato
